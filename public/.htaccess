# Force HTTPS — the session cookie is Secure-only, so plain http produces
# phantom logins (login appears to work, nothing else does).
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# Update-propagation: the entry points must never be served from HTTP cache,
# or browsers sit on stale builds for days. Versioned assets can cache freely.
<IfModule mod_headers.c>
  <FilesMatch "^(index\.html|sw\.js|manifest\.webmanifest)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
